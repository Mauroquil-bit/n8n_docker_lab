# Copiá este archivo como .env y completá los valores
# cp .env.example .env

# Base de datos
POSTGRES_USER=n8n
POSTGRES_PASSWORD=cambiame_por_algo_seguro
POSTGRES_DB=n8n_db

# Clave de encriptación para credenciales de n8n (mínimo 24 caracteres)
N8N_ENCRYPTION_KEY=generá-una-clave-larga-y-aleatoria-aqui

# Zona horaria
GENERIC_TIMEZONE=America/Argentina/Buenos_Aires
